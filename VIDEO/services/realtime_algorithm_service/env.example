# ============================================
# 实时算法服务环境变量配置模板
# ============================================
# 使用方法：
# 1. 复制此文件为 .env: cp env.example .env
# 2. 根据实际情况修改各个配置项
# 3. 注意：.env 文件包含敏感信息，不要提交到版本控制系统
# ============================================

# ============================================
# 基本配置（必需）
# ============================================
# 算法任务ID（必需）
TASK_ID=

# 数据库配置
DATABASE_URL=postgresql://postgres:iot45722414822@localhost:5432/iot-video

# 视频服务端口（默认6000）
VIDEO_SERVICE_PORT=6000

# 网关地址（用于构建完整的告警hook URL，默认http://localhost:48080）
GATEWAY_URL=http://localhost:48080

# RTSP 传输（OpenCV/FFmpeg 拉流）：未单独配置 OPENCV_FFMPEG_CAPTURE_OPTIONS 时生效。
# 建议显式 tcp（抗丢包/Docker）；局域网极低延迟可改为：AI_RTSP_TRANSPORT=udp
# AI_RTSP_TRANSPORT=tcp

# ============================================
# GB28181 虚拟源 gb28181://（播放接口解析后的实际 URL 见日志「GB28181源解析成功」）
# ============================================
# 国标播放地址候选顺序：默认 rtmp_first（让 RTMP 有读者，避免 ZLM 无读者回收整路流）。
# 仅 RTSP 可达时可改为：GB28181_PLAY_PROTOCOL=rtsp_first
# GB28181_PLAY_PROTOCOL=rtmp_first
#
# HEVC/H.265 + RTMP 时 OpenCV 常解码失败：默认在检测到 HEVC 线索时自动优先 RTSP。
# 强制不按 HEVC 规则优先 RTMP：GB28181_HEVC_RTSP_FIRST=0（需自行处理解码/ZLM 保活）
# GB28181_HEVC_RTSP_FIRST=1
#
# OpenCV 无法拉 RTMP（日志 tcp://...?listen）时自动改用播放接口中的 RTSP 地址；关闭：GB28181_OPENCV_RTMP_FALLBACK_RTSP=0
# GB28181_OPENCV_RTMP_FALLBACK_RTSP=1
#
# 国标播放 HTTP API：优先 GB28181_SERVICE_URL，否则 GATEWAY_URL/admin-api/gb28181
# GB28181_SERVICE_URL=http://127.0.0.1:48088/api
#
# OpenCV 拉流：默认在 RTSP/RTMP 上启用后台线程持续 decode，主线程只取最新帧（缓解与业务串行被 fps 限死、灰屏误判）。
# 关闭则恢复同步 read：AI_RTSP_ASYNC_READ=0
# AI_RTSP_ASYNC_READ=1
#
# 异步缓冲深度（默认 1=只保留最新帧、追实时；不写环境变量时代码亦为 1）。需 FIFO 顺播时再显式设置，例如国标/弱网：15～60。
# AI_RTSP_ASYNC_QUEUE_MAX=30

# 告警图片根目录（可选）。不设则落盘到仓库内 VIDEO/alert_images。
# Docker 与 iot-sink 共用宿主机目录时：两边挂载同一路径，且算法进程设置与本仓库 DEVICE/docker-compose 中 iot-sink 一致：
#   宿主机 ./VIDEO/alert_images -> 容器 /app/alert_images
#   ALERT_IMAGES_DIR=/app/alert_images
#ALERT_IMAGES_DIR=/app/alert_images

# ============================================
# 视频处理配置（与 stream_forward_service 对齐的读取优先级）
# ============================================
# 帧率/分辨率：优先 AI_SOURCE_FPS / AI_TARGET_* ，其次 VIEW_SOURCE_FPS / VIEW_TARGET_*（与推流转发一致），再回退 SOURCE_FPS / TARGET_*
# 代码默认与 stream_forward 一致：25fps、1280x720（不在此文件写变量时使用内置默认）
# 以下为「省电/低配」示例；若要与推流转发同款清晰度，请改为 25、1280、720 或删除这些行使用默认
# AI_SOURCE_FPS=25
# AI_TARGET_WIDTH=1280
# AI_TARGET_HEIGHT=720
# VIEW_SOURCE_FPS=25
# VIEW_TARGET_WIDTH=1280
# VIEW_TARGET_HEIGHT=720
SOURCE_FPS=15

TARGET_WIDTH=640

TARGET_HEIGHT=360

# 抽帧间隔（默认2；算法检测每 N 帧抽 1 帧）
EXTRACT_INTERVAL=5

# 帧缓存大小（默认70）
BUFFER_SIZE=70

# 最小缓存帧数（默认15）
MIN_BUFFER_FRAMES=15

# 最大等待时间（秒，默认0.08）
MAX_WAIT_TIME=0.08

# YOLO检测分辨率（默认416，原640，降低可减少CPU占用）
YOLO_IMG_SIZE=416

# ============================================
# FFmpeg（与 stream_forward：优先 AI_FFMPEG_* > VIEW_FFMPEG_* > FFMPEG_*）
# ============================================
# 预设默认 veryfast（与推流转发一致）；低配示例用 ultrafast
FFMPEG_PRESET=ultrafast

# 码率默认 3500k（720p 与 stream_forward 一致）；低配示例用 500k
FFMPEG_VIDEO_BITRATE=500k

# FFmpeg编码线程数（默认不设置，表示自动）
# 如果CPU占用过高，可以设置为较小值（如2或4）来限制线程数
# 注意：设置为空字符串或不设置表示自动，代码会自动处理空值
FFMPEG_THREADS=

# GOP：优先 AI_FFMPEG_GOP_SIZE > VIEW_FFMPEG_GOP_SIZE > FFMPEG_GOP_SIZE；不设则 max(1, SOURCE_FPS*2)
# FFMPEG_GOP_SIZE=

# ============================================
# 队列配置（可选，用于优化高负载场景）
# ============================================
# 检测队列大小（默认100，原50，增大可减少队列满的错误）
# 如果遇到"检测队列已满"警告，可以适当增大此值
DETECTION_QUEUE_SIZE=100

# 推帧队列大小（默认100，原50，增大可减少队列满的错误）
# 如果遇到"推帧队列已满"警告，可以适当增大此值
PUSH_QUEUE_SIZE=100

# 抽帧队列大小（默认50）
EXTRACT_QUEUE_SIZE=50

# YOLO检测工作线程数量（默认2，原1，增大可提升处理能力）
# 如果检测速度跟不上，可以适当增加此值（建议2-4个）
# 注意：线程数过多可能增加CPU占用
YOLO_WORKER_THREADS=2

# ============================================
# 其他配置
# ============================================
# Python输出不缓冲（建议设置为1）
PYTHONUNBUFFERED=1

# 时区设置
TZ=Asia/Shanghai

