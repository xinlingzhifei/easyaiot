# ============================================
# AI服务环境变量配置（生产部署：中间件在独立主机时使用内网 IP）
# ============================================
# 中间件内网地址：10.0.0.87（PostgreSQL / Nacos / MinIO / Kafka 等）
# 数据库名必须为 iot-ai20（iot-ai10 仅为 SQL 初始化文件名，不是库名）
# Kafka 跨机访问：broker 元数据可能返回 Kafka:9092，请在 AI 宿主机 /etc/hosts 添加：
#   10.0.0.87 Kafka
# 注意：此文件包含敏感信息，不要提交到版本控制系统
# ============================================

# ============================================
# Flask应用配置
# ============================================
# Flask密钥（用于会话加密）
SECRET_KEY=8595796f2b6c5aefbc2f0d0442d9fcf7c4142ae27fa2bf14acc2f2b88352a2e35b0c35d17006709a

# Flask运行端口（默认5000）
FLASK_RUN_PORT=5000

# Flask运行主机（默认0.0.0.0）
FLASK_RUN_HOST=0.0.0.0

# Flask调试模式（生产环境建议设置为False）
DEBUG=False

# 允许的主机列表
ALLOWED_HOSTS=[*]

# ============================================
# 数据库配置
# ============================================
# PostgreSQL数据库连接URL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
# 注意：如果使用postgres://开头，代码会自动转换为postgresql://
# 生产环境中间件内网 10.0.0.87；数据库名 iot-ai20（由 install_middleware 创建）
DATABASE_URL=postgresql://postgres:iot45722414822@10.0.0.87:5432/iot-ai20

# ============================================
# Nacos服务注册与发现配置
# ============================================
# Nacos服务器地址（格式：IP:端口）
NACOS_SERVER=10.0.0.87:8848

# Nacos命名空间（与 DEVICE 等 Java 服务 prod 一致，使用 dev）
NACOS_NAMESPACE=dev

# Nacos用户名（默认：nacos）
NACOS_USERNAME=nacos

# Nacos密码
NACOS_PASSWORD=basiclab@iot78475418754

# 服务名称（用于Nacos注册）
SERVICE_NAME=model-server

# Pod IP地址（可选，如果不设置会自动获取）
# 在Docker容器中运行时，建议设置为容器的IP地址
POD_IP=

# ============================================
# MinIO对象存储配置
# ============================================
# MinIO服务器地址（格式：IP:端口）
MINIO_ENDPOINT=10.0.0.87:9000

# MinIO访问密钥
MINIO_ACCESS_KEY=minioadmin

# MinIO密钥
MINIO_SECRET_KEY=basiclab@iot975248395

# MinIO是否使用HTTPS（true/false）
MINIO_SECURE=false

# ============================================
# GPU配置
# ============================================
# CUDA可见设备（0表示使用第一个GPU，all表示使用所有GPU）
# 在docker-compose.yaml中已配置，这里可以覆盖
CUDA_VISIBLE_DEVICES=0

# ============================================
# 讯飞语音识别配置（可选）
# ============================================
# 讯飞APP ID（如果不需要语音识别功能，可以留空）
XUNFEI_APP_ID=

# 讯飞密钥（如果不需要语音识别功能，可以留空）
XUNFEI_SECRET_KEY=

# ============================================
# 推流服务器配置（可选）
# ============================================
# 推流服务器地址（用于推理结果推流）
MODEL_AI_PUSH_URL=10.0.0.87:1935

# ============================================
# 其他配置
# ============================================
# Python输出不缓冲（建议设置为1）
PYTHONUNBUFFERED=1

# 时区设置
TZ=Asia/Shanghai

# ============================================
# Redis配置（可选，如果需要）
# ============================================
# Redis服务器地址（生产环境）
# REDIS_HOST=iot.basiclab.top
# REDIS_PORT=6379
# REDIS_PASSWORD=basiclab@iot975248395

# ============================================
# Kafka配置（可选，如果需要）
# ============================================
# Kafka服务器地址（中间件内网）
KAFKA_BOOTSTRAP_SERVERS=10.0.0.87:9092

# ============================================
# TDengine配置（可选，如果需要）
# ============================================
# TDengine服务器地址（生产环境）
# TDENGINE_HOST=iot.basiclab.top
# TDENGINE_PORT=6030

# ============================================
# 代理配置（可选，如果需要）
# ============================================
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1

# ============================================
# GPU推理配置
# ============================================
# 是否启用GPU推理
USE_GPU=True
# Docker NVIDIA设备可见性
NVIDIA_VISIBLE_DEVICES=all
