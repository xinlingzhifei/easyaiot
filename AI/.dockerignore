# Git / IDE
.git
.gitignore
.idea
.vscode
*.iml
*.ipr
*.iws

# Python 缓存
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/

# 日志与临时文件
*.log
logs/
*.tmp
*.temp
*.swp
*.swo
*~

# 运行时数据（compose 卷挂载，勿打入镜像）
data/
static/
temp_uploads/
model/

# 独立子服务（各自有 Dockerfile / 镜像）
services/ai_service/

# 环境变量（运行时通过卷挂载 .env.docker）
.env
.env.*
!.env.example
.env.prod

# 模型权重（运行时卷挂载）
*.pt
yolo11n/

# 安装 / 缓存脚本
*.sh
cache_resources*.sh
install_linux*.sh
install_mac.sh
!docker-entrypoint.sh

# Docker 构建文件
docker-compose.yaml
docker-compose*.yaml
Dockerfile*
.dockerignore

# 项目根构建缓存（经 --build-context 挂载）
.build-cache

# 测试与开发工具
test_*.py
check_gpu.py
diagnose_*.py
configure_*.py
drop_*.py
add_*.py

# 文档
*.md
README*
LICENSE

# 系统文件
.DS_Store
Thumbs.db
